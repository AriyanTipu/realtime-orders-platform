# Copy to `.env` before running `docker compose up`.
# Every value below is a safe local-development default; replace all
# secrets before any non-local deployment.

# --- Postgres -------------------------------------------------------------
POSTGRES_DB=orders
POSTGRES_USER=orders
POSTGRES_PASSWORD=dev-only-password

# Hostnames as seen from inside the Compose network. When running services
# directly on your machine against the Compose database, use DB_HOST=localhost.
DB_HOST=db
DB_PORT=5432

# --- Redis (Django cache for hot analytics queries) ------------------------
REDIS_URL=redis://redis:6379/0

# --- Django core service ----------------------------------------------------
DJANGO_SECRET_KEY=dev-only-insecure-secret-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,core,proxy
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Enables the /api/demo/* endpoints used by the dashboard's "place test order"
# button. Turn off outside demos.
DEMO_MODE=1
# Used by `manage.py seed_data` to create the admin account.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin-dev-only

# --- FastAPI realtime service -----------------------------------------------
# Must point at the same database the core service writes to; NOTIFY events
# are only visible on the emitting database.
RT_DATABASE_URL=postgresql://orders:dev-only-password@db:5432/orders
RT_LOG_LEVEL=info

# --- Frontend (Vite) ---------------------------------------------------------
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8001
